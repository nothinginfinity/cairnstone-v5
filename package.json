{
  "name": "cairnstone-v5",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FSL CCR Stone v5 runtime for Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply CAIRNSTONE_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply CAIRNSTONE_DB --remote"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
