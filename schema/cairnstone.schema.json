{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentfeedoptimization.com/schemas/cairnstone-v5.schema.json",
  "title": "CairnStone v5",
  "type": "object",
  "required": ["border", "layers"],
  "properties": {
    "border": {
      "type": "object",
      "required": ["hash", "author", "created", "title"],
      "properties": {
        "hash": { "type": "string" },
        "author": { "type": "string" },
        "created": { "type": "string" },
        "title": { "type": "string" },
        "repo": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "parent": { "type": ["string", "null"] },
        "chain": { "type": ["string", "null"] },
        "signature": { "type": ["string", "null"] }
      }
    },
    "layers": {
      "type": "object",
      "required": ["lod5", "lod4", "lod3", "lod2", "lod1"],
      "properties": {
        "lod5": { "type": "string" },
        "lod4": { "type": "string" },
        "lod3": { "type": "string" },
        "lod2": { "type": "object" },
        "lod1": { "type": "object" }
      }
    },
    "related": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" }
  }
}
